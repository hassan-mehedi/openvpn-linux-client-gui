#!/usr/bin/make -f

%:
	dh $@ --with python3

override_dh_auto_build:
	python3 -m build --wheel --no-isolation

override_dh_auto_install:
	rm -rf debian/openvpn3-client-linux
	python3 -m installer --destdir=debian/openvpn3-client-linux dist/*.whl
	python3 packaging/scripts/install_shared_assets.py --destdir debian/openvpn3-client-linux --prefix /usr

override_dh_auto_test:
	:
